# Django boot settings
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me

# Database
DATABASE_URL=postgresql://spooklight:spooklight@127.0.0.1:5433/spooklight
POSTGRES_CONN_MAX_AGE=60

# Async AI tasks
REDIS_URL=redis://127.0.0.1:6379/0
AI_TASK_TIMEOUT_SECONDS=900
AI_TASK_LEASE_SECONDS=900
AI_WORKER_HEARTBEAT_MAX_AGE_SECONDS=120

# AI providers
OPENAI_API_KEY=
